# ASTRO backend environment — copy to backend/.env (never commit the real .env)

# --- Django ---
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Database ---
# Leave empty to use SQLite (dev default). For Postgres (PRD §5.1):
# DATABASE_URL=postgres://user:pass@host:5432/astro
DATABASE_URL=

# --- Google OAuth (django-allauth) ---
# Create credentials at https://console.cloud.google.com (OAuth client, Web app).
# Authorized redirect URI (dev): http://localhost:8000/accounts/google/login/callback/
# Authorized redirect URI (Railway): https://YOUR_DOMAIN/accounts/google/login/callback/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
